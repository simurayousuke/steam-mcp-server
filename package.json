{
  "name": "steam-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only MCP server for Steam public data and Steam Web API data.",
  "bin": {
    "steam-mcp-server": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "audit:steam-catalog": "tsx scripts/audit-steam-catalog.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
