# Optional for public/store endpoints, required for Steam Web API endpoints that need a key.
STEAM_API_KEY=

# Defaults used by store and community endpoints.
STEAM_DEFAULT_COUNTRY=US
STEAM_DEFAULT_LANGUAGE=en

# Network and cache defaults.
STEAM_REQUEST_TIMEOUT_MS=10000
STEAM_CACHE_TTL_SECONDS=300
STEAM_RATE_LIMIT_RPS=2
