# Optional for public/store endpoints, required for Steam Web API endpoints that need a user key.
STEAM_WEB_API_KEY=

# Dangerous by default: publisher keys can access sensitive or protected APIs.
# The server will not call publisher-only methods unless an explicit allowlist enables them.
STEAM_PUBLISHER_KEY=

# Optional Steam OAuth settings. Steam OpenID works without these.
STEAM_OAUTH_CLIENT_ID=
STEAM_OAUTH_CLIENT_SECRET=
STEAM_OAUTH_REDIRECT_URI=

# Local callback server used for OpenID/OAuth authorization.
STEAM_AUTH_CALLBACK_HOST=127.0.0.1
STEAM_AUTH_CALLBACK_PORT=0
STEAM_AUTH_SESSION_DIR=

# Optional allowlist for restricted Web API methods.
STEAM_API_ALLOWLIST_FILE=

# Defaults used by store and community endpoints.
STEAM_DEFAULT_COUNTRY=US
STEAM_DEFAULT_LANGUAGE=en

# Network and cache defaults.
STEAM_REQUEST_TIMEOUT_MS=10000
STEAM_CACHE_TTL_SECONDS=300
STEAM_RATE_LIMIT_RPS=2
